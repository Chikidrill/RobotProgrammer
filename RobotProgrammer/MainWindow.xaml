<Window x:Class="RobotProgrammer.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:actions="clr-namespace:Model.RobotActions;assembly=Model"
        xmlns:model="clr-namespace:Model;assembly=Model"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Robot Programmer" Height="450" Width="800"
        Icon="/Resources/icon.png"
        >
    <Window.Resources>
        <ObjectDataProvider x:Key="VariableTypeValues"
                    MethodName="GetValues"
                    ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="model:ProgramVariableType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Панель кнопок -->
            <RowDefinition Height="Auto"/>
            <!-- Таблица + редактор -->
            <RowDefinition Height="*"/>
            <!-- Лог -->
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Menu Margin="0,0,10,0" BorderThickness="1" BorderBrush="Gray">
                <MenuItem Header="Файл">
                    <MenuItem Header="Сохранить как..."  Command="{Binding SaveAsProjectCommand}" />
                    <MenuItem Header="Открыть проект..." Command="{Binding OpenProjectCommand}" />
                </MenuItem>
            </Menu>
            <Menu Margin="0,0,10,0" BorderThickness="1" BorderBrush="Gray">
                <MenuItem Header="Добавить действие" >
                    <MenuItem Header="Автономный период" >
                        <MenuItem Header="Добавить движение" Command="{Binding AddMoveCommand}" />
                        <MenuItem Header="Добавить паузу" Command="{Binding AddWaitCommand}" />
                        <MenuItem Header="Добавить цикл" Command="{Binding AddLoopCommand}" />
                        <MenuItem Header="Добавить условие" Command="{Binding AddConditionalCommand}" />
                    </MenuItem>
                    <MenuItem Header="Телеуправляемый период">
                        
                    </MenuItem>
                </MenuItem>
            </Menu>

            <Menu Margin="0,0,10,0" BorderThickness="1" BorderBrush="Gray">
                <MenuItem Header="Шаблон">
                    <MenuItem Header="Новый шаблон" Command="{Binding NewTemplateCommand}" />
                    <MenuItem Header="Загрузить шаблон"  Command="{Binding LoadTemplateCommand}" />
                    <MenuItem Header="Редактировать шаблон" Command="{Binding EditTemplateCommand}" />
                </MenuItem>
            </Menu>
            <Menu BorderThickness="1" BorderBrush="Gray">
                <MenuItem Header="Программа">
                    <MenuItem Header="Компилировать" Command="{Binding CompileCommand}" />
                    <MenuItem Header="Загрузить" Command="{Binding UploadCommand}" />
                </MenuItem>
            </Menu>
        </StackPanel>


        <!-- Основная рабочая зона: таблица действий + редактор -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Таблица действий -->
                <ColumnDefinition Width="*"/>
                <!-- Редактор выбранного действия -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Таблица действий -->
            <TabControl Grid.Row="1" SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}">
                <TabItem Header="Variables">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Button Content="Добавить"
                        Width="90"
                        Margin="0,0,5,0"
                        Command="{Binding AddVariableCommand}"/>

                            <Button Content="Удалить"
                        Width="90"
                        Command="{Binding DeleteVariableCommand}"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Variables}"
                      SelectedItem="{Binding SelectedVariable}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">

                            <DataGrid.Columns>

                                <DataGridComboBoxColumn Header="Тип"
                                            SelectedItemBinding="{Binding Type, Mode=TwoWay}"
                                           ItemsSource="{Binding Source={StaticResource VariableTypeValues}}"
                                            Width="90"/>

                                <DataGridTextColumn Header="Название"
                                        Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*"/>

                                <DataGridTextColumn Header="Значение"
                                        Binding="{Binding DefaultValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*"/>

                                <DataGridCheckBoxColumn Header="const"
                                            Binding="{Binding IsConstant, Mode=TwoWay}"
                                            Width="60"/>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="Setup">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                   Text="Setup выполняется один раз при запуске робота. Используй его для инициализации."
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   Margin="0,0,0,5"/>

                        <TreeView x:Name="SetupActionsTree"
                  Grid.Row="1"
                  ItemsSource="{Binding Actions}"
                  SelectedItemChanged="Tree_SelectedItemChanged"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="Tree_PreviewMouseLeftButtonDown"
                  MouseMove="Tree_MouseMove"
                  DragOver="Tree_DragOver"
                  Drop="Tree_Drop">

                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Удалить" Command="{Binding DeleteSelectedCommand}" />
                                    <MenuItem Header="Копировать" Command="{Binding CopySelectedCommand}" />
                                    <MenuItem Header="Вставить" Command="{Binding PasteSelectedCommand}" />
                                </ContextMenu>
                            </TreeView.ContextMenu>

                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <DockPanel>
                                                    <Border x:Name="Bd"
                                            BorderBrush="Gray"
                                            BorderThickness="1"
                                            Background="#FFEFEFEF"
                                            CornerRadius="4"
                                            Padding="5"
                                            Margin="0,0,0,2"
                                            DockPanel.Dock="Top">

                                                        <ContentPresenter x:Name="PART_Header"
                                                          ContentSource="Header"/>
                                                    </Border>

                                                    <ItemsPresenter x:Name="ItemsHost"
                                                    Margin="20,2,0,2"/>
                                                </DockPanel>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FFBEE6FD"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3C7FB1"/>
                                                    </Trigger>

                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FFD9F1FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>

                                <HierarchicalDataTemplate DataType="{x:Type actions:ContainerAction}"
                                          ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayType}"
                               FontWeight="Bold"
                               Foreground="#333"/>
                                </HierarchicalDataTemplate>

                                <DataTemplate DataType="{x:Type actions:RobotAction}">
                                    <TextBlock Text="{Binding DisplayType}"
                               Foreground="#444"/>
                                </DataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </Grid>
                </TabItem>
                <TabItem Header="Autonomous">
                    <Grid>
                        <TreeView x:Name="ActionsTree"
                      ItemsSource="{Binding Actions}"
                      SelectedItemChanged="Tree_SelectedItemChanged"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="Tree_PreviewMouseLeftButtonDown"
                      MouseMove="Tree_MouseMove"
                      DragOver="Tree_DragOver"
                      Drop="Tree_Drop">
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Удалить" Command="{Binding DeleteSelectedCommand}" />
                                    <MenuItem Header="Копировать" Command="{Binding CopySelectedCommand}" />
                                    <MenuItem Header="Вставить" Command="{Binding PasteSelectedCommand}" />
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.Resources>
                                <!-- Общий стиль для всех TreeViewItem -->
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <DockPanel>
                                                    <!-- Заголовок блока -->
                                                    <Border x:Name="Bd" BorderBrush="Gray" BorderThickness="1" Background="#FFEFEFEF" CornerRadius="4" Padding="5" Margin="0,0,0,2" DockPanel.Dock="Top">
                                                        <ContentPresenter x:Name="PART_Header" ContentSource="Header"/>
                                                    </Border>
                                                    <!-- Дочерние элементы -->
                                                    <ItemsPresenter x:Name="ItemsHost" Margin="20,2,0,2"/>
                                                </DockPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FFBEE6FD"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3C7FB1"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FFD9F1FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <!-- HierarchicalDataTemplate для контейнеров -->
                                <HierarchicalDataTemplate DataType="{x:Type actions:ContainerAction}" ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayType}" FontWeight="Bold" Foreground="#333"/>
                                </HierarchicalDataTemplate>
                                <!-- DataTemplate для обычных действий -->
                                <DataTemplate DataType="{x:Type actions:RobotAction}">
                                    <TextBlock Text="{Binding DisplayType}" Foreground="#444"/>
                                </DataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </Grid>
                </TabItem>
                <TabItem Header="Teleop">
                    <Grid>
                        <TreeView x:Name="ActionsTreeTeleop"
                      ItemsSource="{Binding Actions}"
                      SelectedItemChanged="Tree_SelectedItemChanged"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="Tree_PreviewMouseLeftButtonDown"
                      MouseMove="Tree_MouseMove"
                      DragOver="Tree_DragOver"
                      Drop="Tree_Drop">
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Удалить" Command="{Binding DeleteSelectedCommand}" />
                                    <MenuItem Header="Копировать" Command="{Binding CopySelectedCommand}" />
                                    <MenuItem Header="Вставить" Command="{Binding PasteSelectedCommand}" />
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.Resources>
                                <!-- Общий стиль для всех TreeViewItem -->
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <DockPanel>
                                                    <!-- Заголовок блока -->
                                                    <Border x:Name="Bd" BorderBrush="Gray" BorderThickness="1" Background="#FFEFEFEF" CornerRadius="4" Padding="5" Margin="0,0,0,2" DockPanel.Dock="Top">
                                                        <ContentPresenter x:Name="PART_Header" ContentSource="Header"/>
                                                    </Border>
                                                    <!-- Дочерние элементы -->
                                                    <ItemsPresenter x:Name="ItemsHost" Margin="20,2,0,2"/>
                                                </DockPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FFBEE6FD"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3C7FB1"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FFD9F1FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <!-- HierarchicalDataTemplate для контейнеров -->
                                <HierarchicalDataTemplate DataType="{x:Type actions:ContainerAction}" ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayType}" FontWeight="Bold" Foreground="#333"/>
                                </HierarchicalDataTemplate>
                                <!-- DataTemplate для обычных действий -->
                                <DataTemplate DataType="{x:Type actions:RobotAction}">
                                    <TextBlock Text="{Binding DisplayType}" Foreground="#444"/>
                                </DataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Редактор выбранного действия -->
            <Border Grid.Column="1" Padding="10" BorderBrush="Gray" BorderThickness="1">

                <ContentControl Content="{Binding SelectedAction}">
                    <ContentControl.Resources>
                        <!-- Шаблон для MoveAction -->
                        <DataTemplate DataType="{x:Type actions:MoveAction}">
                            <StackPanel>
                                <TextBlock Text="Параметры движения:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <ItemsControl ItemsSource="{Binding Parameters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding Name}" Width="80"/>
                                                <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- Шаблон для WaitAction -->
                        <DataTemplate DataType="{x:Type actions:WaitAction}">
                            <StackPanel>
                                <TextBlock Text="Параметры паузы:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <ItemsControl ItemsSource="{Binding Parameters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding Name}" Width="80"/>
                                                <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                        <!-- Шаблон для CustomAction -->
                        <DataTemplate DataType="{x:Type actions:CustomAction}">
                            <StackPanel>
                                <TextBlock Text="Пользовательский шаблон"/>
                                <TextBlock Text="Имя:"/>
                                <TextBox Text="{Binding TemplateName}" IsReadOnly="True" Margin="0,0,0,5"/>
                                <TextBlock Text="Код:"/>
                                <TextBox Text="{Binding TemplateCode}" IsReadOnly="True" AcceptsReturn="True" Margin="0,0,0,5"/>

                                <TextBlock Text="Параметры:"/>
                                <ItemsControl ItemsSource="{Binding Parameters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" Width="80"/>
                                                <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" IsReadOnly="False"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type actions:LoopAction}">
                            <StackPanel>
                                <TextBlock Text="Цикл"/>
                                <TextBlock Text="Повторов:"/>
                                <TextBox Text="{Binding RepeatCount, Mode=TwoWay}" Width="50"/>
                                <TextBlock Text="Действия внутри цикла:"/>
                                <ItemsControl ItemsSource="{Binding Children}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayType}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- Условие -->
                        <DataTemplate DataType="{x:Type actions:ConditionalAction}">
                            <StackPanel>
                                <TextBlock Text="Условие" FontWeight="Bold"/>

                                <TextBlock Text="Выражение:"/>
                                <TextBox Text="{Binding Condition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Width="180"
                 Margin="0,0,0,10"/>

                                <TextBlock Text="Ветки условия:" FontWeight="Bold"/>

                                <ItemsControl ItemsSource="{Binding Children}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="5"
                            Margin="0,4,0,4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayType}"
                                       FontWeight="Bold"/>

                                                    <ItemsControl ItemsSource="{Binding Children}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding DisplayType}"
                                                   Margin="10,2,0,2"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type actions:BranchAction}">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayType}" FontWeight="Bold"/>
                                <TextBlock Text="Это ветка условия. Перетащи сюда действия." Margin="0,5,0,5"/>

                                <ItemsControl ItemsSource="{Binding Children}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayType}" Margin="10,2,0,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Border>
            <GridSplitter HorizontalAlignment="Left" Height="224" Margin="510,10,0,0" VerticalAlignment="Top" Width="5"/>

        </Grid>


        <!-- Лог -->

        <TabControl Grid.Row="2">
            <TabItem Header="Лог">
                <TextBox Text="{Binding LogString, Mode=OneWay}" 
                     IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </TabItem>
            <TabItem Header="Предварительный код">
                <TextBox Text="{Binding PreviewCode, Mode=OneWay}" 
                     IsReadOnly="True" FontFamily="Consolas" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"/>
            </TabItem>
        </TabControl>

    </Grid>
    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
        <KeyBinding Modifiers="Control" Key="C" Command="{Binding CopySelectedCommand}" />
        <KeyBinding Modifiers="Control" Key="V" Command="{Binding PasteSelectedCommand}" />
    </Window.InputBindings>
</Window>
